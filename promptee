#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN="$SCRIPT_DIR/promptee-bin"

build_project() {
  echo "📦 Starting full build..."

  # Check Docker services
  echo "🐳 Checking Docker services..."
  if ! docker-compose ps 2>/dev/null | grep -q "postgres.*healthy"; then
    echo "  Starting PostgreSQL & Milvus..."
    docker-compose up -d > /dev/null 2>&1
    sleep 3
  else
    echo "  ✓ Services running"
  fi

  # Install Python deps
  echo "📚 Installing Python dependencies..."
  python3 -m pip install -q -r backend/requirements.txt 2>/dev/null || true

  # Build Go binary
  echo "🔨 Building Go binary..."
  make go-build > /dev/null 2>&1
  cp "$SCRIPT_DIR/bin/promptee" "$BIN"
  chmod +x "$BIN"
  echo "  ✓ Binary built"

  # Run tests
  echo "✅ Running tests..."
  PYTHONPATH="$SCRIPT_DIR:$PYTHONPATH" python3 -m pytest backend/tests/ -q --tb=short 2>&1 | tail -5

  echo ""
  echo "✓ Build complete"
}

run_tui() {
  if [ ! -f "$BIN" ] || [ ! -x "$BIN" ]; then
    echo "Binary not found or not executable. Building..."
    build_project
  fi

  # Ensure backend is running
  if ! curl -s http://localhost:8000/api/v1/health > /dev/null 2>&1; then
    echo "Starting backend..."
    cd "$SCRIPT_DIR"
    python3 -m uvicorn backend.app.main:app --host 0.0.0.0 --port 8000 > /dev/null 2>&1 &
    sleep 2
  fi

  exec "$BIN" "$@"
}

case "${1:-}" in
  "build")
    build_project
    ;;
  "")
    # No args - run TUI
    run_tui
    ;;
  *)
    # Pass through to binary
    run_tui "$@"
    ;;
esac
