# Milvus Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530

# FastAPI Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# PostgreSQL Database (recommended for production and local development)
# If PG_HOST is set, uses PostgreSQL. Otherwise falls back to SQLite.
PG_HOST=localhost
PG_PORT=15432
PG_USER=promptee
PG_PASSWORD=promptee_password
PG_DATABASE=promptee

# SQLite Database (fallback when PG_HOST not set)
# PROMPTEE_DB_DIR=./data
# PROMPTEE_DB_PATH=./data/promptee.db

# Embedding Model
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Logging
LOG_LEVEL=INFO
